generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  manager
  staff
  sales
  worker
}

enum VenueStatus {
  active
  inactive
  maintenance
}

enum LeadStatus {
  new
  contacted
  viewing
  offer_sent
  negotiation
  won
  lost
}

enum EventType {
  wedding
  baptism
  birthday
  corporate
  other
}

enum EventStatus {
  draft
  preconfirmed
  confirmed
  in_preparation
  completed
  cancelled
}

enum OfferStatus {
  draft
  sent
  accepted
  rejected
}

enum ContractStatus {
  draft
  signed
  cancelled
}

enum InvoiceStatus {
  unpaid
  partially_paid
  paid
  cancelled
}

enum EfacturaStatus {
  not_submitted
  submitted
  accepted
  rejected
  error
}

enum PaymentMethod {
  cash
  bank_transfer
  card
  stripe
}

enum PaymentStatus {
  pending
  succeeded
  failed
  refunded
}

enum TaskStatus {
  todo
  in_progress
  done
}

model User {
  id                  String               @id @default(uuid())
  organizationId      String
  name                String
  email               String               @unique
  passwordHash        String
  role                UserRole             @default(staff)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  organization        Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tasks               EventTask[]          @relation("AssignedTasks")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  sentInvitations     Invitation[]         @relation("SentInvitations")
  auditLogs           AuditLog[]
  deviceTokens        DeviceToken[]
}

model Organization {
  id                String           @id @default(uuid())
  name              String
  slug              String           @unique
  cif               String?          // CUI/CIF firma (ex: "17042060")
  street            String?          // adresa sediu
  city              String?
  county            String?          // cod judet UBL (ex: "RO-B", "RO-BC")
  iban              String?          // pentru payment_means in UBL
  bankName          String?
  efacturaCompanyId String?          // ID Company in e-factura-api (setat o singura data)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  users             User[]
  venues            Venue[]
  clients           Client[]
  leads             Lead[]
  events            Event[]
  offers            Offer[]
  contracts         Contract[]
  invoices          Invoice[]
  payments          Payment[]
  eventTasks        EventTask[]
  invitations       Invitation[]
  auditLogs         AuditLog[]
  numberSequences   NumberSequence[]
}

model RefreshToken {
  id             String    @id @default(uuid())
  userId         String
  tokenHash      String    @unique
  expiresAt      DateTime
  revokedAt      DateTime?
  replacedByHash String?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Invitation {
  id             String       @id @default(uuid())
  organizationId String
  email          String
  role           UserRole     @default(staff)
  tokenHash      String       @unique
  expiresAt      DateTime
  acceptedAt     DateTime?
  invitedById    String
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy      User         @relation("SentInvitations", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([organizationId, email])
}

model AuditLog {
  id             String        @id @default(uuid())
  organizationId String?
  userId         String?
  action         String
  entity         String
  entityId       String?
  metadata       Json?
  ip             String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([entity, entityId])
}

model NumberSequence {
  id             String       @id @default(uuid())
  organizationId String
  type           String
  prefix         String
  nextValue      Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, type])
}

model Venue {
  id             String       @id @default(uuid())
  organizationId String
  name           String
  address        String
  capacity       Int
  description    String?
  status         VenueStatus  @default(active)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events         Event[]
  offers         Offer[]
}

model Client {
  id             String     @id @default(uuid())
  organizationId String
  fullName       String
  phone          String
  email          String?
  notes          String?
  cif            String?    // CUI client B2B (optional, persoane fizice nu au)
  street         String?
  city           String?
  county         String?    // cod judet UBL (ex: "RO-B")
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  leads          Lead[]
  events         Event[]
  offers         Offer[]
  contracts      Contract[]
  invoices       Invoice[]
  payments       Payment[]
}

model Lead {
  id              String     @id @default(uuid())
  organizationId  String
  clientId        String
  eventType       String
  estimatedGuests Int?
  desiredDate     DateTime?
  status          LeadStatus @default(new)
  source          String?
  notes           String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Event {
  id              String       @id @default(uuid())
  organizationId  String
  clientId        String
  venueId         String
  title           String
  eventType       EventType
  eventDate       DateTime
  startTime       String?
  endTime         String?
  guestsCount     Int
  status          EventStatus  @default(draft)
  totalAmount     Decimal      @default(0) @db.Decimal(12, 2)
  depositAmount   Decimal      @default(0) @db.Decimal(12, 2)
  paidAmount      Decimal      @default(0) @db.Decimal(12, 2)
  remainingAmount Decimal      @default(0) @db.Decimal(12, 2)
  preconfirmedAt     DateTime?
  preconfirmExpiresAt DateTime?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  venue           Venue        @relation(fields: [venueId], references: [id], onDelete: Restrict)
  offers          Offer[]
  contracts       Contract[]
  invoices        Invoice[]
  payments        Payment[]
  tasks           EventTask[]

  @@index([eventDate])
  @@index([venueId, eventDate])
  @@index([organizationId, eventDate])
}

model Offer {
  id              String      @id @default(uuid())
  organizationId  String
  clientId        String
  eventId         String?
  venueId         String
  eventType       EventType
  guestsCount     Int
  selectedPackage String
  totalAmount     Decimal     @db.Decimal(12, 2)
  status          OfferStatus @default(draft)
  validUntil      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  deletedAt       DateTime?
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client          Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  event           Event?      @relation(fields: [eventId], references: [id], onDelete: SetNull)
  venue           Venue       @relation(fields: [venueId], references: [id], onDelete: Restrict)
}

model Contract {
  id             String         @id @default(uuid())
  organizationId String
  eventId        String
  clientId       String
  contractNumber String
  status         ContractStatus @default(draft)
  signedAt       DateTime?
  signatureData  String?        // semnatura clientului salvata ca imagine base64 (data URL PNG)
  signerName     String?        // numele cu care s-a semnat in aplicatie
  signerIp       String?        // IP-ul de la care s-a semnat (audit)
  fileUrl        String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@unique([organizationId, contractNumber])
}

model Invoice {
  id                   String         @id @default(uuid())
  organizationId       String
  eventId              String
  clientId             String
  invoiceNumber        String
  amount               Decimal        @db.Decimal(12, 2)
  status               InvoiceStatus  @default(unpaid)
  dueDate              DateTime?
  fileUrl              String?
  // campuri e-factura / ANAF SPV
  vatRate              Decimal?       @db.Decimal(5, 2)   // ex: 19.00 (procent TVA)
  items                Json?          // linii factura detaliate (optional)
  efacturaStatus       EfacturaStatus @default(not_submitted)
  efacturaUploadIndex  String?        // index_incarcare ANAF
  efacturaMessageId    String?        // id mesaj in SPV (dupa procesare)
  efacturaError        String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  deletedAt            DateTime?
  organization         Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event                Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  client               Client         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  payments             Payment[]

  @@unique([organizationId, invoiceNumber])
}

model Payment {
  id                String        @id @default(uuid())
  organizationId    String
  eventId           String
  invoiceId         String?
  clientId          String
  amount            Decimal       @db.Decimal(12, 2)
  paymentMethod     PaymentMethod
  status            PaymentStatus @default(pending)
  externalPaymentId String?
  paidAt            DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  deletedAt         DateTime?
  organization      Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event             Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invoice           Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  client            Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)

  @@index([externalPaymentId])
}

model DeviceToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  platform   String   @default("expo") // expo | fcm | apns | web
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EventTask {
  id             String     @id @default(uuid())
  organizationId String
  eventId        String
  title          String
  description    String?
  status         TaskStatus @default(todo)
  dueDate        DateTime?
  assignedTo     String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  deletedAt      DateTime?
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  event          Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignee       User?      @relation("AssignedTasks", fields: [assignedTo], references: [id], onDelete: SetNull)
}
