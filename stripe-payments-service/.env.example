# ---- Server ----
NODE_ENV=development
PORT=3000
LOG_LEVEL=info
# CORS: "*" sau lista separata prin virgula: https://app1.com,https://app2.com
CORS_ORIGINS=*

# ---- Stripe ----
# Cheile din dashboard Stripe -> Developers -> API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Secretul webhook -> Developers -> Webhooks -> (endpoint) -> Signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx
# Optional: pin la o versiune de API (gol = versiunea contului)
STRIPE_API_VERSION=

# ---- Autentificare service-to-service ----
# Format: "numeApp:cheie,numeApp2:cheie2"  (numele se ataseaza in metadata si ruteaza webhook-urile)
# Genereaza chei random, ex: openssl rand -hex 32
API_KEYS=gestio:cheie_gestio_aici,dentalflow:cheie_dental_aici

# ---- Forwarding webhook-uri catre aplicatiile tale ----
# Pentru fiecare app, unde trimitem evenimentele procesate:
WEBHOOK_FORWARDS=gestio:https://gestio.ro/api/stripe/webhook,dentalflow:https://dentalflow.ro/api/stripe/webhook
# Fallback daca evenimentul nu are "app" in metadata (optional):
WEBHOOK_FORWARD_URL=
# Secret HMAC cu care semnam payload-ul (header X-Service-Signature). Genereaza random.
WEBHOOK_FORWARD_SECRET=schimba_acest_secret

# ---- Postgres (optional; fara el = stateless) ----
# In docker-compose este setat automat. Local poti folosi:
# DATABASE_URL=postgres://stripe:stripe@localhost:5432/stripe_payments
DATABASE_URL=
POSTGRES_PASSWORD=stripe

# ---- Valori implicite ----
DEFAULT_CURRENCY=ron
DEFAULT_SUCCESS_URL=https://exemplu.ro/success
DEFAULT_CANCEL_URL=https://exemplu.ro/cancel
