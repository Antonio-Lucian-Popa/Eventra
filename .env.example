NODE_ENV=development
PORT=4000
DATABASE_URL="postgresql://eveniment:eveniment@localhost:5432/eveniment_app?schema=public"
JWT_SECRET="change-me-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_DAYS=30
PASSWORD_RESET_MINUTES=30
INVITATION_DAYS=7
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=300
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"
STORAGE_DIR="storage"

# Optional integration with ./stripe-payments-service
STRIPE_PAYMENTS_SERVICE_URL="http://localhost:3000"
STRIPE_PAYMENTS_SERVICE_API_KEY="eveniment-local-api-key"
STRIPE_WEBHOOK_FORWARD_SECRET=""
PAYMENTS_SUCCESS_URL="http://localhost:3000/payments/success?session_id={CHECKOUT_SESSION_ID}"
PAYMENTS_CANCEL_URL="http://localhost:3000/payments/cancelled"
